#include<bits/stdc++.h>
using namespace std;
using ll = long long;

void solve(){
    int n,q;
    cin>>n>>q;
    vector<ll>a(n);
    vector<pair<ll,int>>k(q);
    for(int i = 0;i<n;i++){
        cin>>a[i];
    }

    for(int i = 0;i<q;i++){
        cin>>k[i].first;
        k[i].second = i;
    }

    //prefix sum
    vector<ll>pref(n);
    pref[0] = a[0];
    for(int i = 1;i<n;i++){
        pref[i] = pref[i-1]+a[i];
    }

    //prefix max
    vector<ll>pre_max(n);
    pre_max[0]=a[0];
    for(int i = 1;i<n;i++){
        pre_max[i] = max(pre_max[i-1],a[i]);
    }

    for(int i = 0;i<q;i++){
        auto it = upper_bound(pre_max.begin(),pre_max.end(),k[i].first)-pre_max.begin();
        if(it == 0){
            k[i].first = 0;
        }
        else
            k[i].first = pref[it-1];
    }

    //sort
    sort(k.begin(),k.end(),[](auto &a,auto &b){
        return a.second<b.second;
    });

    // print ans 
    for(int i = 0;i<q;i++){
        cout<<k[i].first<<" ";
    }
    cout<<'\n';

}
int main(){
    ios::sync_with_stdio(false);cin.tie(NULL);

    int t;
    cin>>t;
    while(t--){
	solve();
    }

}
